<!-- Local rules -->

<!-- Vaultwarden authentication monitoring -->
<group name="vaultwarden,authentication_failed">

  <rule id="100100" level="8">
    <if_sid>0</if_sid>
    <location>vaultwarden.log</location>
    <match>Username or password is incorrect</match>
    <description>Vaultwarden: Failed login attempt - master password incorrect</description>
    <group>authentication_failed,pci_dss_10.2.4,gpg13_7.1</group>
  </rule>

  <rule id="100101" level="8">
    <if_sid>0</if_sid>
    <location>vaultwarden.log</location>
    <match>Invalid refresh token</match>
    <description>Vaultwarden: Invalid refresh token - possible repeated failed master password</description>
    <group>authentication_failed</group>
  </rule>

  <rule id="100102" level="10" frequency="3" timeframe="120">
    <if_matched_sid>100100</if_matched_sid>
    <description>Vaultwarden: Multiple failed login attempts - possible brute force</description>
    <group>authentication_failures,pci_dss_10.2.4,pci_dss_10.2.5,gpg13_7.1</group>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

</group>