{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "labels": ["dependencies"],
  "automerge": false,
  "autoApprove": false,
  "packageRules": [
    {
      "matchPackageNames": [
        "postgres",
        "mysql",
        "mariadb",
        "redis",
        "bitnami/redis"
      ],
      "enabled": false
    }
  ]
}
